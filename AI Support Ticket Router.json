        "responses": {
          "values": [
            {
              "content": "=You are an expert customer support classifier.\nAnalyze this support email and extract structured information.\n\nFrom: {{$json[\"From\"]}}\nSubject: {{$json[\"Subject\"]}}\nMessage: {{$json[\"snippet\"]}}\n\nClassify and return ONLY this JSON, no extra text, no markdown:\n{\n  \"category\": \"one of: Billing, Technical, General\",\n  \"urgency\": 0,\n  \"urgency_reason\": \"specific reason based on THIS email\",\n  \"assigned_team\": \"one of: Billing Team, Tech Team, Support Team\",\n  \"summary\": \"1 sentence summary of THIS specific issue\",\n  \"customer_email\": \"sender email address\"\n}\n\nUrgency guide:\n- 9-10: Financial loss, data breach, system down, app crash\n- 7-8: Billing issues, account access problems\n- 5-6: Feature requests, general questions\n- 1-4: Low priority feedback\n\nIMPORTANT: Analyze THIS specific email. Do not use example values."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2,
      "position": [
        848,
        -176
      ],
      "id": "9a897f39-4003-4aa3-940f-b9738fe0c442",
