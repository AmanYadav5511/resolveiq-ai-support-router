    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are a professional customer support agent.\n\nWrite a warm, specific reply to this customer email.\n\nRules:\n- Address their SPECIFIC issue directly\n- Mention the exact problem they described\n- Never use \"[Customer's Name]\" — start with \"Hi there,\"\n- Keep it under 80 words\n- Sound human, not corporate\n- End with \"Best regards, Support Team\"\n\nCustomer Issue: {{$('Email Analyze').item.json.output[0].content[0].text}}\nOriginal Email: {{$('Get many messages').item.json.snippet}}\n\nReturn ONLY the email reply. Plain text only. No subject line."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
