    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const draftReply = $input.item.json.output[0].content[0].text.trim();\n\nconst classificationRaw = $('Email Analyze').item.json.output[0].content[0].text;\nconst cleaned = classificationRaw.replace(/```json|```/g, \"\").trim();\nconst classification = JSON.parse(cleaned);\n\nconst email = $('Get many messages').item.json;\n\nconst ticketId = 'TKT-' + Date.now();\n\nreturn {\n  json: {\n    ticketId,\n    customerEmail: email.From,\n    subject: email.subject || email.Subject || '',\n    message: email.snippet || email.body || email.text || '',\n    category: classification.category,\n    urgency: classification.urgency,\n    urgencyReason: classification.urgency_reason,\n    assignedTeam: classification.assigned_team,\n    draftReply,\n    status: 'New',\n    createdAt: new Date().toISOString()\n  }\n};"
      },
